{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mcpipe.dev/schemas/pipeline/v1.json",
  "title": "mcpipe pipeline v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "steps"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "string" },
    "metadata": { "$ref": "#/$defs/metadata" },
    "schedule": { "$ref": "#/$defs/schedule" },
    "defaults": { "$ref": "#/$defs/defaults" },
    "inputs": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/input" }
    },
    "mcp_servers": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/mcp_server" }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/step" }
    },
    "error_handling": { "$ref": "#/$defs/error_handling" },
    "policy": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/tool_policy" }
    },
    "output": { "$ref": "#/$defs/output" },
    "observability": { "$ref": "#/$defs/observability" }
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "author": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" }
      }
    },
    "schedule": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "cron": { "type": "string" },
        "timezone": { "type": "string" },
        "on_failure": { "type": "string" }
      }
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "timeout_ms": { "type": "integer", "minimum": 1 },
        "retry": { "$ref": "#/$defs/retry" },
        "llm": { "$ref": "#/$defs/llm" }
      }
    },
    "retry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_attempts": { "type": "integer", "minimum": 1 },
        "backoff": { "type": "string", "enum": ["none", "fixed", "exponential"] },
        "backoff_base_ms": { "type": "integer", "minimum": 0 },
        "retryable_errors": { "type": "array", "items": { "type": "string" } }
      }
    },
    "llm": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "backend": { "type": "string" },
        "model": { "type": "string" },
        "temperature": { "type": "number" },
        "max_tokens": { "type": "integer", "minimum": 1 },
        "stream": { "type": "boolean" }
      }
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["string", "enum"] },
        "description": { "type": "string" },
        "required": { "type": "boolean" },
        "example": {},
        "values": { "type": "array", "items": { "type": "string" } },
        "default": {},
        "pattern": { "type": "string" }
      }
    },
    "mcp_server": {
      "type": "object",
      "additionalProperties": false,
      "required": ["transport"],
      "properties": {
        "transport": { "type": "string", "enum": ["stdio", "sse"] },
        "command": { "type": "string" },
        "args": { "type": "array", "items": { "type": "string" } },
        "env": { "type": "object", "additionalProperties": { "type": "string" } },
        "url": { "type": "string" },
        "headers": { "type": "object", "additionalProperties": { "type": "string" } },
        "health_check": { "$ref": "#/$defs/health_check" },
        "reconnect": { "$ref": "#/$defs/reconnect" }
      }
    },
    "health_check": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "interval_ms": { "type": "integer", "minimum": 1 }
      }
    },
    "reconnect": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "max_attempts": { "type": "integer", "minimum": 1 },
        "delay_ms": { "type": "integer", "minimum": 0 }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "prompt", "outputs"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "parallel_group": { "type": "string" },
        "depends_on": { "type": "array", "items": { "type": "string" } },
        "timeout_ms": { "type": "integer", "minimum": 1 },
        "retry": { "$ref": "#/$defs/retry" },
        "llm": { "$ref": "#/$defs/llm" },
        "prompt": { "$ref": "#/$defs/prompt" },
        "tools": { "$ref": "#/$defs/tools" },
        "agent": { "$ref": "#/$defs/agent" },
        "outputs": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    },
    "prompt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["user"],
      "properties": {
        "system": { "type": "string" },
        "user": { "type": "string" }
      }
    },
    "tools": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allow": { "type": "array", "items": { "type": "string" } },
        "deny": { "type": "array", "items": { "type": "string" } }
      }
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "max_iterations": { "type": "integer", "minimum": 1 },
        "stop_on": { "type": "string", "enum": ["no_tool_call"] }
      }
    },
    "error_handling": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "on_step_failure": { "type": "string" },
        "fallback_steps": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/fallback_step" }
        },
        "on_pipeline_failure": { "$ref": "#/$defs/on_pipeline_failure" }
      }
    },
    "fallback_step": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "skip_if_error": { "type": "boolean" },
        "reason": { "type": "string" }
      }
    },
    "tool_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowed_paths": { "type": "array", "items": { "type": "string" } },
        "max_bytes": { "type": "integer", "minimum": 0 },
        "max_calls": { "type": "integer", "minimum": 0 }
      }
    },
    "on_pipeline_failure": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "notify": { "$ref": "#/$defs/notify" }
      }
    },
    "notify": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "channel": { "type": "string" },
        "include_run_id": { "type": "boolean" },
        "include_failed_step": { "type": "boolean" }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "format": { "type": "string" },
        "destination": { "type": "string" },
        "include_run_metadata": { "type": "boolean" },
        "fields": { "type": "array", "items": { "type": "string" } }
      }
    },
    "observability": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "run_history": { "$ref": "#/$defs/run_history" },
        "metrics": { "$ref": "#/$defs/metrics" },
        "dry_run": { "$ref": "#/$defs/dry_run" }
      }
    },
    "run_history": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "storage": { "type": "string" },
        "path": { "type": "string" },
        "retention_days": { "type": "integer", "minimum": 1 }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "emit": { "type": "array", "items": { "type": "string" } }
      }
    },
    "dry_run": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "show_prompt_previews": { "type": "boolean" },
        "show_tool_call_plan": { "type": "boolean" },
        "show_variable_bindings": { "type": "boolean" }
      }
    }
  }
}
